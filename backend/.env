# === QR Task Manager Backend ===

# Firebase Configuration
FIREBASE_PROJECT_ID=qr-task-manager-app
FIREBASE_CREDENTIALS_PATH="firebase-adminsdk.json"

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated origins)
